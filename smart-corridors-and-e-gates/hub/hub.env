# Runtime env for the Smart Corridors & e-Gates Hub.
# Loaded as env_file of the `hub` service in docker-compose.yml.
# All hosts are CONTAINER DNS names on sf-network — NOT localhost.

# ── Upstream sources ──────────────────────────────────────────────────────────
# VPP = SmartFace faceProcessed (legacy graphql-ws). In-network: sf-graphql-api:80 (host :8097).
VPP_SOURCE_ENABLED=true
VPP_GRAPHQL_SCHEMA=ws
VPP_GRAPHQL_HOST=sf-graphql-api
VPP_GRAPHQL_PORT=80
VPP_GRAPHQL_PATH=graphql
# CIGS = identity grouping (modern graphql-transport-ws). In-network: sceg-cigs:80 (host :8096).
CIGS_SOURCE_ENABLED=true
CIGS_GRAPHQL_SCHEMA=ws
CIGS_GRAPHQL_HOST=sceg-cigs
CIGS_GRAPHQL_PORT=80
CIGS_GRAPHQL_PATH=graphql

# ── Internal broker (RabbitMQ) ────────────────────────────────────────────────
# Must match vpp/.env infrastructure defaults.
RABBITMQ_HOST=rmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VIRTUAL_HOST=/

# ── Clearance disposition ─────────────────────────────────────────────────────
# A match against a watchlist in this (comma-separated) allow-list ⇒ GREEN, otherwise RED.
# This id is the seeded "GreenList" watchlist (carried in db/smartface-seed.dump).
VPP_ADAPTER_ALLOWED_WATCHLISTS=8de3af63-b261-40e8-a4ef-ce92653f5643

# ── Units / cameras ───────────────────────────────────────────────────────────
# One CORRIDOR unit "corridor-1" owning both test cameras. An event whose streamId is not
# declared here dead-letters. List multiple camera ids comma-separated in CAMERAS.
FOUNDATION_UNITS_0_ID=corridor-1
FOUNDATION_UNITS_0_TYPE=CORRIDOR
FOUNDATION_UNITS_0_CAMERAS=019ea7fa-3c44-7444-a1ab-73a7a2976669,019ea7fa-62ab-7e96-a280-8c4183fd68e6

# ── Persistence / storage ─────────────────────────────────────────────────────
# Must match vpp/.env MinIO credentials.
# STORAGE_S3_ENDPOINT is set in docker-compose.yml (NOT here) — needs the host LAN IP for presigned URLs.
STORAGE_ENABLED=true
STORAGE_S3_ENABLED=true
STORAGE_S3_BUCKET=corridor-foundation
STORAGE_S3_ACCESS_KEY=minioadmin
STORAGE_S3_SECRET_KEY=minioadmin
STORAGE_S3_REGION=us-east-1
RETENTION_ENABLED=true

# ── GraphiQL IDE ──────────────────────────────────────────────────────────────
GRAPHIQL_ENABLED=true
