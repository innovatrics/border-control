# Smart Corridors & e-Gates — solution layer config
# ─────────────────────────────────────────────────
# This file owns ONLY the solution-specific services (CIGS, Hub, frontend).
# VPP / SmartFace config lives in vpp/.env.
#
# NOTE: the RabbitMQ and MinIO connection values in hub/hub.env
# must match what vpp/.env sets for the shared infrastructure (the defaults do).

# Harbor — Innovatrics public registry for border-control services
HARBOR=registry.dot.innovatrics.com/border-control/

# Corridor Identity Grouping Service
CIGS_VERSION=0.3.1

# Smart Corridors & e-Gates Hub
HUB_VERSION=0.0.2

# Corridor dashboard (Vite/React SPA served by nginx)
FRONTEND_REGISTRY=registry.dot.innovatrics.com/border-control/
FRONTEND_VERSION=6297530a
FRONTEND_PORT=8095
