# SmartFace Access Controller overrides

MQTT__Enabled=false
MQTT__Topic=edge-stream/{sourceId}/access-notifications/{notificationType}

# Blacklist
BlacklistWatchlistIds__0=00000000-0000-0000-0000-000000000001
BlacklistWatchlistIds__1=00000000-0000-0000-0000-000000000002
BlacklistWatchlistIds__2=00000000-0000-0000-0000-000000000003

# Debounce
OpeningDebounceMs=4000
BlockingDebounceMs=4000

# Camera exclusivity
ExclusiveCameraMode__Enabled=true
ExclusiveCameraMode__ExclusivityWindowMs=5000

# Not-identified handling
NotIdentifiedPersonRoamingLimitMs=3000

# Stream groups
StreamGroups__OpeningDebounceMs=3000

# Disabled filters
FaceOrdering__Enabled=false
FaceMaskDetection__Enabled=false
IntentionalAccessPrediction__Enabled=false
SpoofDetection__Enabled=false
ExpressionAngleValidation__Enabled=false

# Jaeger (disabled)
AppSettings__USE_JAEGER_APP_SETTINGS=false
Jaeger__AgentHost=jaeger
Jaeger__AgentPort=6831
